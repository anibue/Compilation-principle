=== COMPILE PL0 ===
  0 PROGRAM E110; 
  0 VAR B,C; 
  1 BEGIN 
  2    READ(B); 
  4    IF B<>0 THEN 
  7    BEGIN 
  8      C:=5; 
 10      WRITE(C) 
 12    END 
 13   ELSE 
 13    BEGIN 
 14     C:=6; 
 16     WRITE(C) 
 18    END 
 19 END.  
  0  JMP   0   1
  1  INI   0   5
  2  OPR   0  16
  3  STO   0   3
  4  LOD   0   3
  5  LIT   0   0
  6  OPR   0   9
  7  JPC   0  14
  8  LIT   0   5
  9  STO   0   4
 10  LOD   0   4
 11  OPR   0  14
 12  OPR   0  15
 13  JMP   0  19
 14  LIT   0   6
 15  STO   0   4
 16  LOD   0   4
 17  OPR   0  14
 18  OPR   0  15
 19  OPR   0   0
~~~ RUN PL0 ~~~
? 0
6
~~~ END PL0 ~~~

