=== COMPILE PL0 ===
  0 PROGRAM E3; 
  0 VAR A, B; 
  1 PROCEDURE MULTIPLY; 
  1 BEGIN 
  3   A := A * B 
  5 END; 
  1  JMP   0   2
  2  INI   0   3
  3  LOD   1   3
  4  LOD   1   4
  5  OPR   0   4
  6  STO   1   3
  7  OPR   0   0
  8 BEGIN 
  9   A := 3; 
 11   B := 7; 
 13   CALL MULTIPLY; 
 14   WRITE(A) 
 16 END. 
  0  JMP   0   8
  1  JMP   0   2
  2  INI   0   3
  3  LOD   1   3
  4  LOD   1   4
  5  OPR   0   4
  6  STO   1   3
  7  OPR   0   0
  8  INI   0   5
  9  LIT   0   3
 10  STO   0   3
 11  LIT   0   7
 12  STO   0   4
 13  CAL   0   2
 14  LOD   0   3
 15  OPR   0  14
 16  OPR   0  15
 17  OPR   0   0
~~~ RUN PL0 ~~~
21
~~~ END PL0 ~~~

